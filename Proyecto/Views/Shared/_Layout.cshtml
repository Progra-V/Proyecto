@using Microsoft.AspNetCore.Http

@{
    var session = Context.Session.GetString("session");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - HelpDesk Pro</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/category.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/Proyecto.styles.css" asp-append-version="true" />
</head>

<body>

    @if (!string.IsNullOrEmpty(session))
    {
        <div class="d-flex">

            <aside class="sidebar shadow">
                <div class="sidebar-header">
                    <h4 class="fw-bold text-white">
                        <i class="bi bi-ticket-perforated-fill"></i>
                        HelpDesk
                    </h4>
                </div>

                <partial name="_NavMenu" />
            </aside>

            <div class="main-content flex-grow-1">
                <partial name="_TopNavbar" />

                <main class="container-fluid py-4">
                    @RenderBody()
                </main>
            </div>

        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>