@model List<Proyecto.Models.Ticket>

<div class="card shadow-sm border-0 h-100">

    <div class="card-header bg-white d-flex justify-content-between align-items-center">

        <div>

            <h5 class="mb-0 fw-semibold">

                Recent Activity

            </h5>

            <small class="text-muted">

                Latest tickets in the system

            </small>

        </div>

        <a asp-controller="Ticket"
           asp-action="Index"
           class="btn btn-outline-primary btn-sm">

            View All

        </a>

    </div>

    <div class="card-body p-0">

        @if (!Model.Any())
        {
            <div class="text-center p-5">

                <i class="bi bi-ticket-perforated display-4 text-secondary"></i>

                <h5 class="mt-3">

                    No recent activity

                </h5>

            </div>
        }
        else
        {

            @foreach (var ticket in Model.OrderByDescending(x => x.CreatedAt).Take(8))
            {

                string statusClass = ticket.Status.ToLower() switch
                {
                    "open" => "bg-primary",
                    "pending" => "bg-warning text-dark",
                    "in progress" => "bg-info text-dark",
                    "closed" => "bg-success",
                    _ => "bg-secondary"
                };

                string priorityClass = ticket.Priority.ToLower() switch
                {
                    "high" => "bg-danger",
                    "medium" => "bg-warning text-dark",
                    "low" => "bg-success",
                    _ => "bg-secondary"
                };

                <div class="ticket-row">

                    <div class="ticket-icon">

                        <i class="bi bi-ticket-perforated-fill"></i>

                    </div>

                    <div class="ticket-content">

                        <strong>

                            @ticket.Title

                        </strong>

                        <div class="text-muted small">

                            Ticket #@ticket.Id

                        </div>

                        <div class="mt-2">

                            <span class="badge @statusClass">

                                @ticket.Status

                            </span>

                            <span class="badge @priorityClass ms-2">

                                @ticket.Priority

                            </span>

                        </div>

                    </div>

                    <div>

                        <a asp-controller="Ticket"
                           asp-action="Detail"
                           asp-route-id="@ticket.Id"
                           class="btn btn-light">

                            <i class="bi bi-arrow-right"></i>

                        </a>

                    </div>

                </div>

            }

        }

    </div>

</div>