@model Proyecto.ViewModels.DashboardViewModel

<div class="row g-4">

    <!-- Total Tickets -->
    <div class="col-xl-3 col-md-6">

        <div class="card dashboard-card dashboard-primary h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">

                    <i class="bi bi-ticket-perforated-fill"></i>

                </div>

                <h1 class="dashboard-number">

                    @Model.TotalTickets

                </h1>

                <h5>

                    Total Tickets

                </h5>

                <small class="text-muted">

                    All registered tickets

                </small>

            </div>

        </div>

    </div>


    <!-- Pending -->

    <div class="col-xl-3 col-md-6">

        <div class="card dashboard-card dashboard-warning h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">

                    <i class="bi bi-hourglass-split"></i>

                </div>

                <h1 class="dashboard-number">

                    @Model.PendingTickets

                </h1>

                <h5>

                    Pending

                </h5>

                <small class="text-muted">

                    Waiting for review

                </small>

            </div>

        </div>

    </div>


    <!-- In Progress -->

    <div class="col-xl-3 col-md-6">

        <div class="card dashboard-card dashboard-info h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">

                    <i class="bi bi-arrow-repeat"></i>

                </div>

                <h1 class="dashboard-number">

                    @Model.InProgressTickets

                </h1>

                <h5>

                    In Progress

                </h5>

                <small class="text-muted">

                    Currently being processed

                </small>

            </div>

        </div>

    </div>


    <!-- Closed -->

    <div class="col-xl-3 col-md-6">

        <div class="card dashboard-card dashboard-success h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">

                    <i class="bi bi-check-circle-fill"></i>

                </div>

                <h1 class="dashboard-number">

                    @Model.ClosedTickets

                </h1>

                <h5>

                    Closed

                </h5>

                <small class="text-muted">

                    Successfully resolved

                </small>

            </div>

        </div>

    </div>

</div>