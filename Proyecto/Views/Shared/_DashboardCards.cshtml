@model Proyecto.ViewModels.DashboardViewModel

<div class="row g-4">

    <!-- Total Tickets -->
    <div class="col-xl-2 col-md-4 col-sm-6">

        <div class="card dashboard-card dashboard-primary h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">
                    <i class="bi bi-ticket-perforated-fill"></i>
                </div>

                <h1 class="dashboard-number">
                    @Model.TotalTickets
                </h1>

                <h5>
                    Total Tickets
                </h5>

                <small class="text-muted">
                    Tickets registrados
                </small>

            </div>

        </div>

    </div>


    <!-- Pendientes -->
    <div class="col-xl-2 col-md-4 col-sm-6">

        <div class="card dashboard-card dashboard-warning h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>

                <h1 class="dashboard-number">
                    @Model.PendingTickets
                </h1>

                <h5>
                    Pendientes
                </h5>

                <small class="text-muted">
                    Recién creados
                </small>

            </div>

        </div>

    </div>


    <!-- En Revisión -->
    <div class="col-xl-2 col-md-4 col-sm-6">

        <div class="card dashboard-card dashboard-pink h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">
                    <i class="bi bi-search"></i>
                </div>

                <h1 class="dashboard-number">
                    @Model.InReviewTickets
                </h1>

                <h5>
                    En Revisión
                </h5>

                <small class="text-muted">
                    Evaluando el caso
                </small>

            </div>

        </div>

    </div>


    <!-- En Progreso -->
    <div class="col-xl-2 col-md-4 col-sm-6">

        <div class="card dashboard-card dashboard-info h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">
                    <i class="bi bi-arrow-repeat"></i>
                </div>

                <h1 class="dashboard-number">
                    @Model.InProgressTickets
                </h1>

                <h5>
                    En Progreso
                </h5>

                <small class="text-muted">
                    Actualmente en proceso
                </small>

            </div>

        </div>

    </div>


    <!-- Finalizados -->
    <div class="col-xl-2 col-md-4 col-sm-6">

        <div class="card dashboard-card dashboard-success h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>

                <h1 class="dashboard-number">
                    @Model.CompletedTickets
                </h1>

                <h5>
                    Finalizados
                </h5>

                <small class="text-muted">
                    Tickets resueltos
                </small>

            </div>

        </div>

    </div>


    <!-- Cancelados -->
    <div class="col-xl-2 col-md-4 col-sm-6">

        <div class="card dashboard-card dashboard-danger h-100">

            <div class="card-body">

                <div class="dashboard-card-icon">
                    <i class="bi bi-x-circle-fill"></i>
                </div>

                <h1 class="dashboard-number">
                    @Model.CancelledTickets
                </h1>

                <h5>
                    Cancelados
                </h5>

                <small class="text-muted">
                    No serán atendidos
                </small>

            </div>

        </div>

    </div>

</div>