@using Proyecto.Models

@{
    var navList = ViewData["CustomNavMenu"] as List<NavigationPages> ?? new List<NavigationPages>();

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();

    var groupedMenu = navList.GroupBy(x => x.Section);
}

<div class="sidebar-menu">

    @foreach (var menuSection in groupedMenu)
    {
        <div class="menu-section">

            <small class="menu-title">
                @menuSection.Key.ToUpper()
            </small>

            <ul class="nav flex-column mb-4">

                @foreach (var item in menuSection)
                {
                    <li class="nav-item">

                        <a class="nav-link sidebar-link @(currentController == item.Controller ? "active" : "")"
                           asp-controller="@item.Controller"
                           asp-action="@item.Action"
                           onclick="@(item.RequiresConfirmation ? "return confirm('¿Está seguro de cerrar sesión?');" : "")">

                            <i class="bi @item.Icon me-3"></i>

                            @item.Title

                        </a>

                    </li>
                }

            </ul>

        </div>
    }

</div>