@model List<Proyecto.Models.ViewModels.CategoryViewModel>

@{
    ViewData["Title"] = "Categorías";
}

<div class="container py-5">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-5">

        <div>
            <h1 class="display-5 fw-bold text-primary mb-2">
                Categorías
            </h1>

            <p class="text-muted fs-5 mb-0">
                Administre las categorías registradas en el sistema.
            </p>
        </div>

        <a asp-controller="Category"
           asp-action="Create"
           class="btn btn-primary">
            Nueva categoría
        </a>

    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"
             role="alert">

            @TempData["SuccessMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    <div class="mb-4">

        <span class="badge bg-secondary px-3 py-2 fs-6">
            Total de registros: @(Model?.Count ?? 0)
        </span>

    </div>

    <div class="table-responsive shadow-sm rounded-3">

        <table class="table table-hover table-striped align-middle mb-0 bg-white">

            <thead class="table-dark text-uppercase">

                <tr>

                    <th>ID</th>

                    <th>Departamento</th>

                    <th>Nombre</th>

                    <th>Descripción</th>

                    <th class="text-center">Estado</th>

                    <th>Fecha de creación</th>

                    <th class="text-center">Acciones</th>

                </tr>

            </thead>

            <tbody>

                @if (Model == null || !Model.Any())
                {
                    <tr>

                        <td colspan="7"
                            class="text-center py-4 text-muted">

                            No hay categorías registradas.

                        </td>

                    </tr>
                }
                else
                {
                    foreach (var category in Model)
                    {
                        <tr>

                            <td class="fw-bold">
                                @category.Id
                            </td>

                            <td>

                                <span class="badge bg-primary">
                                    @category.DepartmentName
                                </span>

                            </td>

                            <td>
                                @category.Name
                            </td>

                            <td>

                                @(string.IsNullOrWhiteSpace(category.Description)
                                    ? "Sin descripción"
                                    : category.Description)

                            </td>

                            <td class="text-center">

                                @if (category.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Activa
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Inactiva
                                    </span>
                                }

                            </td>

                            <td>
                                @category.CreatedAt.ToString("dd/MM/yyyy")
                            </td>

                            <td class="text-center">

                                <div class="d-flex flex-wrap justify-content-center gap-2">

                                    <a asp-controller="Category"
                                       asp-action="Edit"
                                       asp-route-id="@category.Id"
                                       class="btn btn-warning btn-sm">

                                        Editar

                                    </a>

                                    <form asp-controller="Category"
                                          asp-action="ChangeStatus"
                                          asp-route-id="@category.Id"
                                          method="post"
                                          class="d-inline">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-outline-@(category.IsActive ? "danger" : "success") btn-sm">

                                            @(category.IsActive ? "Desactivar" : "Activar")

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>