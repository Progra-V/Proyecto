@model Proyecto.Models.Category

@{
    ViewData["Title"] = "Editar categoría";
}

<div class="container-fluid">

    <div class="mb-4">

        <h2 class="fw-bold">
            Editar categoría
        </h2>

        <p class="text-muted">
            Modifique la información de la categoría.
        </p>

    </div>

    <form asp-action="Edit"
          method="post">

        <input asp-for="Id"
               type="hidden" />

        <input asp-for="CreatedAt"
               type="hidden" />

        <input asp-for="IsActive"
               type="hidden" />

        <partial name="_CategoryForm"
                 model="Model" />

    </form>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}