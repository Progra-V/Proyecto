@model Proyecto.Models.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="container-fluid">

    <div class="category-header mb-4">

        <h2 class="fw-bold">

            Edit Category

        </h2>

        <p class="text-muted">

            Update category information.

        </p>

    </div>

    <form asp-action="Edit"
          method="post">

        <input asp-for="Id"
               type="hidden" />

        <input asp-for="DepartmentId"
               type="hidden" />

        <input asp-for="CreatedAt"
               type="hidden" />

        <input asp-for="IsActive"
               type="hidden" />

        <partial name="_CategoryForm"
                 model="Model" />

    </form>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}