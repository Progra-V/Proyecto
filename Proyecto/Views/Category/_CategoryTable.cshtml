@model List<Proyecto.Models.Category>

@if (!Model.Any())
{
    <div class="text-center py-5">

        <i class="bi bi-folder-x display-4 text-secondary"></i>

        <h5 class="mt-3">

            No categories found

        </h5>

        <p class="text-muted">

            There are currently no registered categories.

        </p>

    </div>
}
else
{
    <div class="table-responsive">

        <table class="table table-hover align-middle">

            <thead class="table-light">

                <tr>

                    <th style="width:80px;">
                        ID
                    </th>

                    <th style="width:220px;">
                        Name
                    </th>

                    <th>
                        Description
                    </th>

                    <th style="width:130px;">
                        Status
                    </th>

                    <th style="width:170px;" class="text-center">
                        Actions
                    </th>

                </tr>

            </thead>

            <tbody>

                @foreach (var category in Model.OrderBy(x => x.Name))
                {
                    <tr>

                        <td>

                            <strong>

                                #@category.Id

                            </strong>

                        </td>

                        <td>

                            @category.Name

                        </td>

                        <td>

                            @(string.IsNullOrWhiteSpace(category.Description)
                                ? "-"
                                : category.Description)

                        </td>

                        <td>

                            @if (category.IsActive)
                            {
                                <span class="badge bg-success">

                                    Active

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">

                                    Inactive

                                </span>
                            }

                        </td>

                        <td class="text-center">

                            <a asp-action="Edit"
                               asp-route-id="@category.Id"
                               class="btn btn-outline-primary btn-sm">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            @if (category.IsActive)
                            {
                                <a asp-action="Disable"
                                   asp-route-id="@category.Id"
                                   class="btn btn-outline-danger btn-sm ms-2"
                                   onclick="return confirm('Are you sure you want to disable this category?');">

                                    <i class="bi bi-slash-circle"></i>

                                </a>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
}