@model List<Proyecto.Models.User>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="display-5 fw-bold text-primary mb-1">
                Usuarios
            </h1>

            <p class="text-muted fs-5 mb-2">
                Administración de usuarios del sistema.
            </p>

            <span class="badge bg-secondary px-3 py-2 fs-6">
                Total de registros: @(Model?.Count ?? 0)
            </span>

        </div>

        <a asp-controller="User"
           asp-action="Create"
           class="btn btn-primary">

            <i class="bi bi-person-plus"></i>
            Crear usuario

        </a>

    </div>


    <div class="table-responsive shadow-sm rounded-3">

        <table class="table table-hover table-striped align-middle mb-0">


            <thead class="table-dark">

                <tr>

                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Email</th>
                    <th>Teléfono</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Acciones</th>

                </tr>

            </thead>


            <tbody>


                @if (Model == null || !Model.Any())
                {

                    <tr>

                        <td colspan="8"
                            class="text-center py-4 text-muted">

                            No hay usuarios registrados.

                        </td>

                    </tr>

                }
                else
                {

                    foreach (var user in Model)
                    {

                        <tr>


                            <td>
                                @user.Id
                            </td>


                            <td>
                                @user.FirstName
                            </td>


                            <td>
                                @user.LastName
                            </td>


                            <td>
                                @user.Email
                            </td>


                            <td>
                                @user.Phone
                            </td>

                            <td>

                                @switch (user.RoleId)
                                {

                                    case 3:

                                        <span class="badge bg-warning text-dark">
                                            SuperUsuario
                                        </span>

                                        break;


                                    case 2:

                                        <span class="badge bg-primary">
                                            Técnico
                                        </span>

                                        break;


                                    case 1:

                                        <span class="badge bg-success">
                                            Empleado
                                        </span>

                                        break;


                                    default:

                                        <span class="badge bg-secondary">
                                            Sin asignar
                                        </span>

                                        break;

                                }

                            </td>




                            <td>

                                @if (user.IsActive)
                                {

                                    <span class="badge bg-success">
                                        Activo
                                    </span>

                                }
                                else
                                {

                                    <span class="badge bg-danger">
                                        Inactivo
                                    </span>

                                }

                            </td>




                            <td>


                                @if (user.RoleId != 3)
                                {

                                    <form asp-controller="User"
                                          asp-action="ChangeStatus"
                                          method="post"
                                          class="d-inline">


                                        <input type="hidden"
                                               name="id"
                                               value="@user.Id" />


                                        <button type="submit"
                                                class="btn btn-sm @(user.IsActive ? "btn-danger" : "btn-success")">


                                            @(user.IsActive
                                                ? "Desactivar"
                                                : "Activar")


                                        </button>


                                    </form>

                                }
                                else
                                {
      
                                    <span class="badge bg-warning text-dark">
                                        Usuario protegido
                                    </span>
                                }


                            </td>


                        </tr>

                    }

                }


            </tbody>


        </table>


    </div>


</div>