@model List<Proyecto.Models.Ticket>

<div class="table-responsive shadow-sm rounded-3">

    <table class="table table-hover table-striped align-middle mb-0 bg-white">

        <thead class="table-dark text-uppercase">
            <tr>
                <th>Código</th>
                <th>Título</th>
                <th>Departamento</th>
                <th class="text-center">Estado</th>
                <th class="text-center">Prioridad</th>
                <th>Fecha de creación</th>
            </tr>
        </thead>

        <tbody>

            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        No hay tickets registrados.
                    </td>
                </tr>
            }
            else
            {
                foreach (var ticket in Model)
                {
                    var statusClass = ticket.Status switch
                    {
                        "Pendiente" => "bg-secondary",
                        "En Revisión" => "bg-info text-dark",
                        "En Progreso" => "bg-warning text-dark",
                        "Cancelado" => "bg-dark",
                        "Finalizado" => "bg-success",
                        _ => "bg-light text-dark border"
                    };

                    var priorityClass = ticket.Priority switch
                    {
                        "Alta" => "bg-danger",
                        "Media" => "bg-warning text-dark",
                        "Baja" => "bg-success",
                        _ => "bg-light text-dark border"
                    };

                    <tr onclick="window.location.href='/Ticket/Detail?id=@ticket.Id'"
                        style="cursor:pointer">

                        <td class="fw-bold">
                            @ticket.TicketCode
                        </td>

                        <td>
                            @ticket.Title
                        </td>

                        <td>
                            @(ticket.DepartmentName ?? "Sin departamento")
                        </td>

                        <td class="text-center">
                            <span class="badge @statusClass">
                                @ticket.Status
                            </span>
                        </td>

                        <td class="text-center">
                            <span class="badge @priorityClass">
                                @ticket.Priority
                            </span>
                        </td>

                        <td>
                            @ticket.CreatedAt.ToString("dd/MM/yyyy")
                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>
