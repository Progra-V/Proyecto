@model Ticket

@{
    ViewData["Title"] = "Ticket Detail";

    string statusClass = Model.Status?.ToLower() switch
    {
        "open" or "abierto" => "bg-success",
        "in progress" or "en progreso" => "bg-warning text-dark",
        "closed" or "cerrado" or "done" => "bg-secondary",
        "blocked" or "bloqueado" => "bg-danger",
        _ => "bg-light text-dark border"
    };

    string priorityClass = Model.Priority?.ToLower() switch
    {
        "high" or "alta" => "bg-danger",
        "medium" or "media" => "bg-warning text-dark",
        "low" or "baja" => "bg-info text-dark",
        _ => "bg-light text-dark border"
    };
}
<a asp-action="Index"
   class="btn btn-outline-secondary btn-sm float-end">
    Back to Tickets
</a>

<div class="container py-5" style="max-width:900px;">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <span class="badge bg-secondary text-uppercase small">@Model.TicketType</span>
                <span class="text-muted fw-bold">#@Model.Id</span>
            </div>
            <h1 class="h2 text-dark mb-0 fw-bold">@Model.Title</h1>
        </div>

        <div class="d-flex gap-2">
            <span class="badge @statusClass px-3 py-2 fs-6">@Model.Status</span>
            <span class="badge @priorityClass px-3 py-2 fs-6">@Model.Priority</span>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">

            <h5 class="text-muted small text-uppercase fw-bold mb-2">
                Description
            </h5>

            <div class="p-3 bg-light rounded-3 border-start border-primary border-3"
                 style="white-space:pre-line;">
                @(string.IsNullOrEmpty(Model.Description)
                    ? "No description provided for this ticket."
                    : Model.Description)
            </div>

            <hr class="my-4">

            <div class="row g-4">

                <div class="col-md-3">
                    <span class="text-muted small text-uppercase fw-semibold">
                        Created By
                    </span>
                    <p class="mb-0">
                        @(Model.CreatedBy ?? "System")
                    </p>
                </div>

                <div class="col-md-3">
                    <span class="text-muted small text-uppercase fw-semibold">
                        Assigned To
                    </span>
                    <p class="mb-0">
                        @(Model.AssignedTo ?? "Unassigned")
                    </p>
                </div>

                <div class="col-md-3">
                    <span class="text-muted small text-uppercase fw-semibold">
                        Due Date
                    </span>
                    <p class="mb-0">
                        @(Model.DueDate.HasValue
                            ? Model.DueDate.Value.ToString("dd MMM yyyy")
                            : "No due date")
                    </p>
                </div>

                <div class="col-md-3">
                    <span class="text-muted small text-uppercase fw-semibold">
                        Updated
                    </span>
                    <p class="mb-0">
                        @Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
                    </p>
                </div>

            </div>

        </div>

        <div class="card-footer bg-light border-0 px-4 py-3">
            <span class="text-muted small">
                Created on @Model.CreatedAt.ToString("dd MMMM yyyy HH:mm")
            </span>

            
        </div>
    </div>


    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0 fw-bold">
                Comments (@(Model.Comments?.Count ?? 0))
            </h5>
        </div>

        <div class="card-body">

            @if (Model.Comments != null && Model.Comments.Any())
            {
                foreach (var comment in Model.Comments)
                {
                    <div class="mb-3 p-3 bg-light rounded border">

                        <div class="d-flex justify-content-between">
                            <strong>
                                @(comment.CreatedBy ?? "Anonymous")
                            </strong>

                            <small class="text-muted">
                                @comment.CreatedAt.ToString("dd MMM yyyy HH:mm")
                            </small>
                        </div>

                        <p class="mb-0 mt-2">
                            @(comment.CommentText ?? "No content")
                        </p>

                        @if (comment.CreatedBy == Model.ActiveSessionUserId)
                        {
                            <a href="/Ticket/DeleteComment?ticketId=@comment.TicketId&commentId=@comment.Id">
                                Delete
                            </a>
                        }

                    </div>
                }
            }


            <form action="PostComment" method="post">

                <input name="ticketId"
                       type="hidden"
                       value="@Model.Id" />

                <textarea name="commentText"
                          class="form-control mb-2"
                          rows="3"
                          placeholder="Write your comment here..."></textarea>

                <button type="submit"
                        class="btn btn-primary btn-sm">
                    Post Comment
                </button>

            </form>

        </div>

    </div>

</div>