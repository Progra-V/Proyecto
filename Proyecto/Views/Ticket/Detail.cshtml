
@model TicketViewModels

@{
    ViewData["Title"] = "Ticket Detail";

    string statusClass = Model.Ticket.Status?.ToLower() switch
    {
        "open" or "abierto" or "pendiente" => "bg-success",
        "in progress" or "en progreso" => "bg-warning text-dark",
        "closed" or "cerrado" or "finalizado" => "bg-secondary",
        "blocked" or "bloqueado" or "cancelado" => "bg-danger",
        _ => "bg-light text-dark border"
    };

    string priorityClass = Model.Ticket.Priority?.ToLower() switch
    {
        "high" or "alta" => "bg-danger",
        "medium" or "media" => "bg-warning text-dark",
        "low" or "baja" => "bg-info text-dark",
        _ => "bg-light text-dark border"
    };
}

<a asp-action="Index"
   class="btn btn-outline-secondary btn-sm float-end">
    Back to Tickets
</a>


<div class="container py-5" style="max-width:900px;">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">

        <div>
            <div class="d-flex align-items-center gap-2 mb-1">

                <span class="badge bg-secondary text-uppercase small">
                    @Model.Ticket.TicketType
                </span>

                <span class="text-muted fw-bold">
                    #@Model.Ticket.Id
                </span>

            </div>

            <h1 class="h2 text-dark mb-0 fw-bold">
                @Model.Ticket.Title
            </h1>

        </div>


        <div class="d-flex gap-2">

            <span class="badge @statusClass px-3 py-2 fs-6">
                @Model.Ticket.Status
            </span>

            <span class="badge @priorityClass px-3 py-2 fs-6">
                @Model.Ticket.Priority
            </span>

        </div>

    </div>



    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body p-4">

            <h5 class="text-muted small text-uppercase fw-bold mb-2">
                Description
            </h5>


            <div class="p-3 bg-light rounded-3 border-start border-primary border-3"
                 style="white-space:pre-line;">

                @(string.IsNullOrEmpty(Model.Ticket.Description)
                    ? "No description provided for this ticket."
                    : Model.Ticket.Description)

            </div>


            <hr class="my-4">


            <div class="row g-4">

                <div class="col-md-3">

                    <span class="text-muted small text-uppercase fw-semibold">
                        Created By
                    </span>

                    <p class="mb-0">
                        @(Model.Ticket.CreatedBy ?? "System")
                    </p>

                </div>


                <div class="col-md-3">

                    <span class="text-muted small text-uppercase fw-semibold">
                        Assigned To
                    </span>

                    <p class="mb-0">
                        @(Model.Ticket.AssignedTo ?? "Unassigned")
                    </p>

                </div>

                <div class="col-md-3">

    <span class="text-muted small text-uppercase fw-semibold">
        Department
    </span>

    <p class="mb-0">
        @(Model.DepartmentName ?? "Sin departamento")
    </p>

</div>


                <div class="col-md-3">

                    <span class="text-muted small text-uppercase fw-semibold">
                        Due Date
                    </span>

                    <p class="mb-0">

                        @(Model.Ticket.DueDate.HasValue
                            ? Model.Ticket.DueDate.Value.ToString("dd MMM yyyy")
                            : "No due date")

                    </p>

                </div>


                <div class="col-md-3">

                    <span class="text-muted small text-uppercase fw-semibold">
                        Updated
                    </span>

                    <p class="mb-0">
                        @Model.Ticket.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
                    </p>

                </div>

            </div>


        </div>


        <div class="card-footer bg-light border-0 px-4 py-3">

            <span class="text-muted small">
                Created on @Model.Ticket.CreatedAt.ToString("dd MMMM yyyy HH:mm")
            </span>

        </div>


    </div>




    <!-- CAMBIAR ESTADO -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header bg-white">

            <h5 class="mb-0 fw-bold">
                Change Status
            </h5>

        </div>


        <div class="card-body">

            <form asp-action="ChangeStatus" method="post">


                <input type="hidden"
                       name="ticketId"
                       value="@Model.Ticket.Id" />



                <select name="newStatus" class="form-select mb-3">


                    <option value="Pendiente"
                            selected="@(Model.Ticket.Status == "Pendiente")">
                        Pendiente
                    </option>


                    <option value="En Revisión"
                            selected="@(Model.Ticket.Status == "En Revisión")">
                        En Revisión
                    </option>


                    <option value="En Progreso"
                            selected="@(Model.Ticket.Status == "En Progreso")">
                        En Progreso
                    </option>


                    <option value="Finalizado"
                            selected="@(Model.Ticket.Status == "Finalizado")">
                        Finalizado
                    </option>


                    <option value="Cancelado"
                            selected="@(Model.Ticket.Status == "Cancelado")">
                        Cancelado
                    </option>


                </select>



                <button type="submit"
                        class="btn btn-primary">
                    Cambiar Estado
                </button>


            </form>

        </div>

    </div>




    <!-- COMENTARIOS -->


    <div class="card shadow-sm border-0">


        <div class="card-header bg-white">

            <h5 class="mb-0 fw-bold">

                Comments (@(Model.Comments?.Count ?? 0))

            </h5>

        </div>



        <div class="card-body">


            @if (Model.Comments != null && Model.Comments.Any())
            {

                foreach (var comment in Model.Comments)
                {

                    <div class="mb-3 p-3 bg-light rounded border">


                        <div class="d-flex justify-content-between">

                            <strong>
                                @(comment.CreatedBy ?? "Anonymous")
                            </strong>


                            <small class="text-muted">
                                @comment.CreatedAt.ToString("dd MMM yyyy HH:mm")
                            </small>

                        </div>



                        <p class="mb-0 mt-2">

                            @(comment.CommentText ?? "No content")

                        </p>



                        @if (comment.CreatedBy == Model.ActiveSessionUserId)
                        {

                            <a href="/Ticket/DeleteComment?ticketId=@comment.TicketId&commentId=@comment.Id">
                                Delete
                            </a>

                        }


                    </div>

                }

            }



            <form action="PostComment" method="post">


                <input name="ticketId"
                       type="hidden"
                       value="@Model.Ticket.Id" />



                <textarea name="commentText"
                          class="form-control mb-2"
                          rows="3"
                          placeholder="Write your comment here..."></textarea>



                <button type="submit"
                        class="btn btn-primary btn-sm">

                    Post Comment

                </button>


            </form>


        </div>


    </div>


</div>