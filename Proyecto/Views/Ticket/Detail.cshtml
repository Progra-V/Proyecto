<div class="card shadow-sm border-0 mb-4">

    <div class="card-header bg-white">
        <h5 class="mb-0 fw-bold">
            Actualizar Ticket
        </h5>
    </div>

    <div class="card-body">

        <form asp-action="UpdateTicket" method="post">

            <input type="hidden"
                   name="ticketId"
                   value="@Model.Ticket.Id" />

            <div class="row g-3">

                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Estado
                    </label>

                    <select name="status" class="form-select">
                        <option value="Pending" selected="@(Model.Ticket.Status == "Pending")">
                            Pendiente
                        </option>

                        <option value="In Review" selected="@(Model.Ticket.Status == "In Review")">
                            En Revisión
                        </option>

                        <option value="In Progress" selected="@(Model.Ticket.Status == "In Progress")">
                            En Progreso
                        </option>

                        <option value="Completed" selected="@(Model.Ticket.Status == "Completed")">
                            Finalizado
                        </option>

                        <option value="Cancelled" selected="@(Model.Ticket.Status == "Cancelled")">
                            Cancelado
                        </option>
                    </select>
                </div>


                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Prioridad
                    </label>

                    <select name="priority" class="form-select">

                        <option value="High" selected="@(Model.Ticket.Priority == "High")">
                            Alta
                        </option>

                        <option value="Medium" selected="@(Model.Ticket.Priority == "Medium")">
                            Media
                        </option>

                        <option value="Low" selected="@(Model.Ticket.Priority == "Low")">
                            Baja
                        </option>

                    </select>
                </div>


                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Riesgo
                    </label>

                    <select name="risk" class="form-select">

                        <option value="High" selected="@(Model.Ticket.Risk == "High")">
                            Alto
                        </option>

                        <option value="Medium" selected="@(Model.Ticket.Risk == "Medium")">
                            Medio
                        </option>

                        <option value="Low" selected="@(Model.Ticket.Risk == "Low")">
                            Bajo
                        </option>

                    </select>
                </div>


                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Categoría
                    </label>

                    <select name="category" class="form-select">

                        <option value="Hardware" selected="@(Model.Ticket.Category == "Hardware")">
                            Hardware
                        </option>

                        <option value="Software" selected="@(Model.Ticket.Category == "Software")">
                            Software
                        </option>

                        <option value="Security" selected="@(Model.Ticket.Category == "Security")">
                            Seguridad
                        </option>

                    </select>
                </div>


                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Departamento
                    </label>

                    <select name="departmentId" class="form-select">

                        @if (Model.Departments != null)
                        {
                            foreach (var department in Model.Departments)
                            {
                                <option value="@department.Id"
                                        selected="@(department.Id == Model.Ticket.DepartmentId)">
                                    @department.Name
                                </option>
                            }
                        }

                    </select>
                </div>


                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Técnico asignado
                    </label>

                    <select name="assignedTo" class="form-select">

                        <option value="">
                            Sin asignar
                        </option>

                        @if (Model.Technicians != null)
                        {
                            foreach (var user in Model.Technicians)
                            {
                                <option value="@user.Id"
                                        selected="@(user.Id == Model.Ticket.AssignedTo)">
                                    @user.FirstName @user.LastName
                                </option>
                            }
                        }

                    </select>
                </div>

            </div>

            <button type="submit"
                    class="btn btn-primary mt-4">
                Guardar cambios
            </button>

        </form>

    </div>

</div>