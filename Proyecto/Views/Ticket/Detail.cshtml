<div class="card shadow-sm border-0 mb-4">

    <div class="card-body p-4">

        <h5 class="text-muted small text-uppercase fw-bold mb-2">
            Descripción
        </h5>

        <div class="p-3 bg-light rounded-3 border-start border-primary border-3"
             style="white-space:pre-line;">

            @(string.IsNullOrEmpty(Model.Ticket.Description)
                ? "Sin descripción."
                : Model.Ticket.Description)

        </div>

        <hr class="my-4">

        <div class="row g-4">

            <div class="col-md-3">
                <span class="text-muted small text-uppercase fw-semibold">
                    Solicitante
                </span>

                <p class="mb-0">
                    @(Model.Ticket.CreatedByName ?? "Desconocido")
                </p>
            </div>


            <div class="col-md-3">
                <span class="text-muted small text-uppercase fw-semibold">
                    Técnico asignado
                </span>

                <p class="mb-0">
                    @(Model.Ticket.AssignedToName ?? "Sin asignar")
                </p>
            </div>


            <div class="col-md-3">
                <span class="text-muted small text-uppercase fw-semibold">
                    Departamento
                </span>

                <p class="mb-0">
                    @(Model.DepartmentName ?? "Sin departamento")
                </p>
            </div>


            <div class="col-md-3">
                <span class="text-muted small text-uppercase fw-semibold">
                    Fecha límite
                </span>

                <p class="mb-0">
                    @(Model.Ticket.DueDate == default(DateTime)
                        ? "Sin fecha"
                        : Model.Ticket.DueDate.ToString("dd/MM/yyyy"))
                </p>
            </div>

        </div>

    </div>


    <div class="card-footer bg-light border-0 px-4 py-3">

        <span class="text-muted small">
            Creado:
            @Model.Ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </span>

    </div>

</div>