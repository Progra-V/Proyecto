@model Proyecto.Models.TicketViewModels

@{
    ViewData["Title"] = "Editar Ticket";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container py-4">

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Editar Ticket @Model.Ticket.TicketCode</h3>

                <a asp-action="Detail" asp-route-id="@Model.Ticket.Id" class="btn btn-light btn-sm">
                    Volver
                </a>
            </div>
        </div>

        <div class="card-body">

            <form asp-action="UpdateTicket" method="post">

                <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                <input type="hidden" name="assignedTo" value="@Model.Ticket.AssignedTo" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Departamento</label>
                        <select name="departmentId" id="departmentSelect" class="form-select">
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(d.Id == Model.Ticket.DepartmentId)">
                                    @d.Name (@d.Code)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Categoría</label>
                        <select name="categoryId" id="categorySelect" class="form-select">
                            @if (Model.Ticket.CategoryId.HasValue)
                            {
                                <option value="@Model.Ticket.CategoryId" selected>
                                    @Model.Ticket.CategoryName
                                </option>
                            }
                            @foreach (var c in Model.Categories)
                            {
                                if (c.Id != Model.Ticket.CategoryId)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            }
                        </select>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-semibold">Estado</label>
                        <select name="status" class="form-select">
                            @foreach (var s in new[] { "Pendiente", "En Revisión", "En Progreso", "Cancelado", "Finalizado" })
                            {
                                <option value="@s" selected="@(Model.Ticket.Status == s)">@s</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-semibold">Prioridad</label>
                        <select name="priority" class="form-select">
                            @foreach (var p in new[] { "Baja", "Media", "Alta" })
                            {
                                <option value="@p" selected="@(Model.Ticket.Priority == p)">@p</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-semibold">Riesgo</label>
                        <select name="risk" class="form-select">
                            @foreach (var r in new[] { "Bajo", "Medio", "Alto" })
                            {
                                <option value="@r" selected="@(Model.Ticket.Risk == r)">@r</option>
                            }
                        </select>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Técnico asignado</label>
                        <input type="text"
                               class="form-control"
                               value="@(Model.Ticket.AssignedToName ?? "No asignado")"
                               readonly />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold">Fecha límite</label>
                        <input type="date"
                               name="dueDate"
                               class="form-control"
                               value="@(Model.Ticket.DueDate?.ToString("yyyy-MM-dd"))" />
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Detail" asp-route-id="@Model.Ticket.Id" class="btn btn-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-success">
                        Guardar cambios
                    </button>
                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        document
            .getElementById("departmentSelect")
            .addEventListener("change", async function() {

                const departmentId = this.value;
                const categorySelect = document.getElementById("categorySelect");

                categorySelect.innerHTML = "<option>Cargando...</option>";

                if (departmentId === "") {
                    categorySelect.innerHTML = "<option value=''>Seleccione...</option>";
                    return;
                }

                const response = await fetch(`/Ticket/GetCategories?departmentId=${departmentId}`);
                const categories = await response.json();

                categorySelect.innerHTML = "<option value=''>Seleccione...</option>";

                categories.forEach(category => {
                    categorySelect.innerHTML +=
                        `<option value="${category.id}">${category.name}</option>`;
                });

            });

    </script>
}