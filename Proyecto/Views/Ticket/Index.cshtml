@model List<Proyecto.Models.Ticket>

@{
    ViewData["Title"] = "Tickets";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="display-5 fw-bold text-primary mb-1">
                Tickets
            </h1>

            <p class="text-muted fs-5 mb-2">
                Gestión y seguimiento de incidencias del sistema.
            </p>

            <span class="badge bg-secondary px-3 py-2 fs-6">
                Total de registros: @(Model?.Count ?? 0)
            </span>

        </div>

        <div>

            <a asp-action="Create" class="btn btn-success btn-lg">
                <i class="bi bi-plus-circle me-2"></i>
                Nuevo Ticket
            </a>

        </div>

    </div>

    <partial name="_TicketTable" model="Model" />

</div>