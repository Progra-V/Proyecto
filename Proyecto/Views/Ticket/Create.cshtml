@model Proyecto.Models.TicketViewModels

@{
    ViewData["Title"] = "Nuevo Ticket";

    const int EmployeeRole = 3;
}

<div class="container py-4">

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                Nuevo Ticket
            </h3>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger"></div>

                <div class="mb-3">

                    <label asp-for="Ticket.Title"
                           class="form-label">
                    </label>

                    <input asp-for="Ticket.Title"
                           class="form-control"
                           placeholder="Título del ticket" />

                    <span asp-validation-for="Ticket.Title"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Ticket.Description"
                           class="form-label">
                    </label>

                    <textarea asp-for="Ticket.Description"
                              rows="4"
                              class="form-control"
                              placeholder="Describe el problema"></textarea>

                    <span asp-validation-for="Ticket.Description"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Ticket.Justification"
                           class="form-label">
                    </label>

                    <textarea asp-for="Ticket.Justification"
                              rows="3"
                              class="form-control"></textarea>

                    <span asp-validation-for="Ticket.Justification"
                          class="text-danger"></span>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Departamento
                        </label>

                        <select asp-for="Ticket.DepartmentId"
                                id="departmentSelect"
                                class="form-select">

                            <option value="">
                                Seleccione...
                            </option>

                            @foreach (var department in Model.Departments)
                            {
                                <option value="@department.Id">
                                    @department.Name
                                </option>
                            }

                        </select>

                        <span asp-validation-for="Ticket.DepartmentId"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Categoría
                        </label>

                        <select asp-for="Ticket.CategoryId"
                                id="categorySelect"
                                class="form-select">

                            <option value="">
                                Seleccione...
                            </option>

                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id">
                                    @category.Name
                                </option>
                            }

                        </select>

                        <span asp-validation-for="Ticket.CategoryId"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Asignar a
                    </label>

                    @if (Model.CurrentUser.RoleId == EmployeeRole)
                    {
                        <div class="alert alert-info mb-0">
                            Este ticket será enviado sin asignar.
                        </div>
                    }
                    else
                    {
                        <select asp-for="Ticket.AssignedTo"
                                class="form-select">

                            <option value="">
                                Sin asignar
                            </option>

                            <option value="@Model.CurrentUser.Id">
                                Asignarme este ticket
                            </option>

                            @foreach (var user in Model.AssignableUsers)
                            {
                                if (user.Id != Model.CurrentUser.Id)
                                {
                                    <option value="@user.Id">
                                        @user.FirstName @user.LastName
                                    </option>
                                }
                            }

                        </select>
                    }

                </div>
                                <div class="row">

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Prioridad
                        </label>

                        <select asp-for="Ticket.Priority"
                                class="form-select">

                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>

                        </select>

                        <span asp-validation-for="Ticket.Priority"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Riesgo
                        </label>

                        <select asp-for="Ticket.Risk"
                                class="form-select">

                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>

                        </select>

                        <span asp-validation-for="Ticket.Risk"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Fecha límite
                        </label>

                        <input asp-for="Ticket.DueDate"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="Ticket.DueDate"
                              class="text-danger"></span>

                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Cancelar

                    </a>

                    <button type="submit"
                            class="btn btn-success">

                        Crear Ticket

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>

        document
            .getElementById("departmentSelect")
            .addEventListener("change", async function () {

                const departmentId = this.value;

                const categorySelect =
                    document.getElementById("categorySelect");

                categorySelect.innerHTML =
                    "<option>Cargando...</option>";

                if (departmentId === "") {

                    categorySelect.innerHTML =
                        "<option value=''>Seleccione un departamento primero</option>";

                    return;
                }

                const response =
                    await fetch(`/Ticket/GetCategories?departmentId=${departmentId}`);

                const categories =
                    await response.json();

                categorySelect.innerHTML =
                    "<option value=''>Seleccione...</option>";

                categories.forEach(category => {

                    categorySelect.innerHTML +=
                        `<option value="${category.id}">
                            ${category.name}
                        </option>`;

                });

            });

    </script>
}