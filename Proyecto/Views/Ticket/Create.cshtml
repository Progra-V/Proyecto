@model TicketViewModels

@{
    ViewData["Title"] = "Crear Ticket";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">
    Volver a Tickets
</a>

<div class="container" style="max-width:700px;">

    <h1 class="h3 mb-4">Nuevo Ticket</h1>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label fw-semibold">Asunto</label>
            <input asp-for="Ticket.Title" class="form-control" />
            <span asp-validation-for="Ticket.Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Descripción</label>
            <textarea asp-for="Ticket.Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Justificación</label>
            <textarea asp-for="Ticket.Justification" class="form-control" rows="2"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Riesgo</label>
            <select asp-for="Ticket.Risk" class="form-select">
                @foreach (var r in new[] { "Bajo", "Medio", "Alto" })
                {
                    <option value="@r">@r</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Categoría</label>
            <select asp-for="Ticket.Category" class="form-select">
                @foreach (var c in new[] { "Hardware", "Software", "Red", "Accesos", "Otro" })
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Prioridad</label>
            <select asp-for="Ticket.Priority" class="form-select">
                @foreach (var p in new[] { "Baja", "Media", "Alta" })
                {
                    <option value="@p" selected="@(p == "Media")">@p</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Sistema</label>
            <select asp-for="Ticket.DepartmentId" class="form-select">
                @foreach (var d in Model.Departments)
                {
                    <option value="@d.Id">@d.Name (@d.Code)</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Fecha límite</label>
            <input asp-for="Ticket.DueDate" type="date" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Crear ticket</button>
    </form>

</div>