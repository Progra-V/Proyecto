@model Proyecto.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Mi erfil";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container py-4" style="max-width:700px;">

    <h3 class="fw-bold mb-4">Mi Perfil</h3>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0 fw-bold">Mis datos</h5>
        </div>

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-6">
                    <span class="text-muted small text-uppercase fw-semibold">Nombre</span>
                    <p class="mb-0">@Model.CurrentUser.FirstName @Model.CurrentUser.LastName</p>
                </div>

                <div class="col-md-6">
                    <span class="text-muted small text-uppercase fw-semibold">Correo</span>
                    <p class="mb-0">@Model.CurrentUser.Email</p>
                </div>

                <div class="col-md-6">
                    <span class="text-muted small text-uppercase fw-semibold">Rol</span>
                    <p class="mb-0">
                        @(Model.CurrentUser.RoleId switch
                        {
                            1 => "Empleado",
                            2 => "Soporte Técnico",
                            3 => "Super Usuario",
                            _ => "Desconocido"
                        })
                    </p>
                </div>

                <div class="col-md-6">
                    <span class="text-muted small text-uppercase fw-semibold">Estado</span>
                    <p class="mb-0">
                        @(Model.CurrentUser.IsActive ? "Activo" : "Inactivo")
                    </p>
                </div>

            </div>

        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0 fw-bold">Número de teléfono</h5>
        </div>

        <div class="card-body">

            <form asp-controller="Profile" asp-action="UpdatePhone" method="post">

                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">Teléfono</label>
                    <input type="text"
                           name="phone"
                           class="form-control"
                           value="@Model.Phone"
                           placeholder="Ej. 8888-8888"
                           required />
                </div>

                <button type="submit" class="btn btn-primary btn-sm">
                    Guardar teléfono
                </button>

            </form>

        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white">
            <h5 class="mb-0 fw-bold">Cambiar contraseña</h5>
        </div>

        <div class="card-body">

            <p class="text-muted small">
                Al cambiar tu contraseña, se cerrará tu sesión y deberás iniciar sesión de nuevo.
            </p>

            <form asp-controller="Profile"
                  asp-action="ChangePassword"
                  method="post"
                  onsubmit="return confirm('¿Está seguro de cambiar su contraseña?');">

                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Nueva contraseña
                    </label>

                    <input type="password"
                           name="newPassword"
                           class="form-control"
                           minlength="6"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Confirmar contraseña
                    </label>

                    <input type="password"
                           name="confirmPassword"
                           class="form-control"
                           minlength="6"
                           required />
                </div>

                <button type="submit"
                        class="btn btn-warning btn-sm">

                    Cambiar contraseña

                </button>

            </form>

        </div>
    </div>

</div>
