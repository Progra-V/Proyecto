@model List<Proyecto.Models.Department>

@{
    ViewData["Title"] = "Departamentos";
}

<div class="container py-5">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-5">

        <div>
            <h1 class="display-5 fw-bold text-primary mb-2">
                Departamentos
            </h1>

            <p class="text-muted fs-5 mb-0">
                Administre los departamentos registrados en el sistema.
            </p>
            <div class="mb-4">
                <span class="badge bg-secondary px-3 py-2 fs-6">
                    Total de registros: @(Model?.Count ?? 0)
                </span>
            </div>
        </div>

        <a asp-controller="Department"
           asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-person-plus"></i>
            Crear departamento
        </a>

    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"
             role="alert">

            @TempData["SuccessMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    

    <div class="table-responsive shadow-sm rounded-3">

        <table class="table table-hover table-striped align-middle mb-0 bg-white">

            <thead class="table-dark text-uppercase">

                <tr>
                    <th>ID</th>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th class="text-center">Estado</th>
                    <th>Fecha de creación</th>
                    <th class="text-center">Acciones</th>
                </tr>

            </thead>

            <tbody>

                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="7"
                            class="text-center py-4 text-muted">
                            No hay departamentos registrados.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var department in Model)
                    {
                        <tr>

                            <td class="fw-bold">
                                @department.Id
                            </td>

                            <td>
                                <span class="badge bg-primary">
                                    @department.Code
                                </span>
                            </td>

                            <td>
                                @department.Name
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(department.Description)
                                    ? "Sin descripción"
                                    : department.Description)
                            </td>

                            <td class="text-center">

                                @if (department.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Inactivo
                                    </span>
                                }

                            </td>

                            <td>
                                @department.CreatedAt.ToString("dd/MM/yyyy")
                            </td>

                            <td class="text-center">

                                <div class="d-flex flex-wrap justify-content-center gap-2">

                                    <a asp-controller="Department"
                                       asp-action="Edit"
                                       asp-route-id="@department.Id"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <form asp-controller="Department"
                                          asp-action="ChangeStatus"
                                          asp-route-id="@department.Id"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-outline-@(department.IsActive ? "danger" : "success") btn-sm">

                                            @(department.IsActive ? "Desactivar" : "Activar")

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>