@model Proyecto.Models.Department

@{
    ViewData["Title"] = "Editar departamento";
}

<div class="container py-5" style="max-width: 800px;">

    <div class="mb-4">

        <h1 class="display-6 fw-bold text-primary">
            Editar departamento
        </h1>

        <p class="text-muted fs-5">
            Modifique la información del departamento seleccionado.
        </p>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-dark text-white py-3">

            <h5 class="mb-0 fw-bold">
                Información del departamento
            </h5>

        </div>

        <div class="card-body p-4">

            <form asp-controller="Department"
                  asp-action="Edit"
                  method="post">

                @Html.AntiForgeryToken()

                <input asp-for="Id"
                       type="hidden" />

                <input asp-for="FechaCreacion"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="mb-4">

                    <label asp-for="Nombre"
                           class="form-label fw-semibold">

                        Nombre
                    </label>

                    <input asp-for="Nombre"
                           class="form-control" />

                    <span asp-validation-for="Nombre"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                    <label asp-for="Descripcion"
                           class="form-label fw-semibold">

                        Descripción
                    </label>

                    <textarea asp-for="Descripcion"
                              class="form-control"
                              rows="4"></textarea>

                    <span asp-validation-for="Descripcion"
                          class="text-danger">
                    </span>

                </div>

                <div class="form-check form-switch mb-4">

                    <input asp-for="Activo"
                           class="form-check-input"
                           type="checkbox" />

                    <label asp-for="Activo"
                           class="form-check-label fw-semibold">

                        Departamento activo
                    </label>

                </div>

                <div class="d-flex flex-wrap gap-2">

                    <button type="submit"
                            class="btn btn-primary">

                        Guardar cambios
                    </button>

                    <a asp-controller="Department"
                       asp-action="Index"
                       class="btn btn-outline-secondary">

                        Cancelar
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}