@model Proyecto.Models.Department

@{
    ViewData["Title"] = "Crear departamento";
}

<div class="container py-5" style="max-width:800px;">

    <div class="mb-4">

        <h1 class="display-6 fw-bold text-primary">
            Crear departamento
        </h1>

        <p class="text-muted fs-5">
            Complete la información para registrar un nuevo departamento.
        </p>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-dark text-white py-3">

            <h5 class="mb-0 fw-bold">
                Información del departamento
            </h5>

        </div>

        <div class="card-body p-4">

            <form asp-controller="Department"
                  asp-action="Create"
                  method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>


                <div class="mb-4">

                    <label asp-for="Code"
                           class="form-label fw-semibold">
                        Código
                    </label>

                    <input asp-for="Code"
                           class="form-control"
                           placeholder="Ejemplo: TI" />

                    <span asp-validation-for="Code"
                          class="text-danger">
                    </span>

                    <small class="text-muted">
                        Código utilizado para generar los códigos de tickets.
                    </small>

                </div>


                <div class="mb-4">

                    <label asp-for="Name"
                           class="form-label fw-semibold">
                        Nombre
                    </label>

                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Ejemplo: Tecnologías de Información" />

                    <span asp-validation-for="Name"
                          class="text-danger">
                    </span>

                </div>


                <div class="mb-4">

                    <label asp-for="Description"
                           class="form-label fw-semibold">
                        Descripción
                    </label>

                    <textarea asp-for="Description"
                              class="form-control"
                              rows="4"
                              placeholder="Ingrese una descripción del departamento"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger">
                    </span>

                </div>


                <div class="form-check form-switch mb-4">

                    <input asp-for="IsActive"
                           class="form-check-input"
                           type="checkbox" />

                    <label asp-for="IsActive"
                           class="form-check-label fw-semibold">
                        Departamento activo
                    </label>

                </div>


                <div class="d-flex flex-wrap gap-2">

                    <button type="submit"
                            class="btn btn-primary">
                        Guardar departamento
                    </button>

                    <a asp-controller="Department"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}